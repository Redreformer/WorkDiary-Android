<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base app theme — Compose handles UI, this is just for splash/window chrome -->
    <style name="Theme.WorkDiary" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@color/navy_900</item>
        <item name="android:statusBarColor">@color/navy_900</item>
        <item name="android:navigationBarColor">@color/navy_900</item>
    </style>

    <!-- Splash screen theme -->
    <style name="Theme.WorkDiary.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/navy_900</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.WorkDiary</item>
    </style>
</resources>
